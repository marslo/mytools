	"customCss": "/* ── wide layout ─────────────────────────────────────────────── */\n/* Constrain and center the main page layout to 85 vw							*/\n[class*=\"PageLayoutRoot\"] {\n  max-width: min(85vw, 100%) !important;\n  min-width: 900px !important;\n  margin-left: auto !important;\n	margin-right: auto !important;\n}\n\n/* Expand inner content wrappers tagged as \"large\" to fill the		 */\n/* constrained PageLayoutRoot (e.g. repo file view, wiki)				 */\n[data-width=\"large\"] {\n  max-width: 100% !important;\n	width: 100% !important;\n}\n\n/* Expand markdown / README containers scoped inside PageLayoutRoot */\n[class*=\"PageLayoutRoot\"] .container-lg,\n[class*=\"PageLayoutRoot\"] .container-xl {\n  max-width: 100% !important;\n}\n\n/* ── PR / Issue list ─────────────────────────────────────────── */\n/* The list sits outside PageLayoutRoot, so widen it separately	 */\n.js-check-all-container.container-xl {\n  max-width: min(85vw, 100%) !important;\n  width: 100% !important;\n}\n\n/* ── PR Files changed tab: restore default layout ────────────── */\n/* #diff-comparison-viewer-container[data-side-panel-open] exists */\n/* on all PR tabs, but the side-panel attribute is unique to the  */\n/* diff viewer — revert wide overrides to avoid stretching diffs  */\nbody:has(#diff-comparison-viewer-container[data-side-panel-open]) [class*=\"PageLayoutRoot\"] {\n	max-width: revert !important;\n  min-width: revert !important;\n	width: revert !important;\n  margin-left: revert !important;\n	margin-right: revert !important;\n}\n\n/* ── Releases page: keep left metadata column narrow ─────────── */\n.col-md-2.flex-md-column {\n  flex: 0 0 auto !important;\n  width: auto !important;\n	max-width: 200px !important;\n}\n\n/* ── Refined GitHub: suppress token-limit warning flash ──────── */\n[class*=\"rgh-\"] .flash.flash-error {\n  display: none !important;\n}\n\n/* ── PR list: fix metadata row layout ────────────────────────── */\n/* GitHub dynamically injects style=\"word-break: break-all\" on		*/\n/* the metadata row; override it and prevent flex children from		*/\n/* wrapping (Refined GitHub also sets flex-basis: 100% on this	 */\n/* row via its align-issue-labels feature)												 */\n.js-check-all-container div[style*=\"word-break: break-all\"] {\n	word-break: normal !important;\n	flex-wrap: nowrap !important;\n}\n\n/* author / opened-by: shrinks to make room for metadata,				 */\n/* but never grows — overflow is hidden to truncate long names		*/\n.js-check-all-container .opened-by {\n	flex: 0 1 auto !important;\n	overflow: hidden !important;\n	white-space: nowrap !important;\n  min-width: 0 !important;\n}\n\n/* metadata badge group: fixed natural width, never shrinks,			*/\n/* children (• Review required / ⊙ updated / ↑↓ To) stay inline  */\n.js-check-all-container .d-none.d-md-inline-flex {\n  flex: 0 0 auto !important;\n  flex-wrap: nowrap !important;\n}\n\n/* keep \"• Review required\" on a single line within its container */\n.js-check-all-container .d-none.d-md-inline-flex .d-inline-block.ml-1 {\n	white-space: nowrap !important;\n}",
